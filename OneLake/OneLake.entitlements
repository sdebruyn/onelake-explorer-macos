<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.application-groups</key>
	<array>
		<string>$(TeamIdentifierPrefix)group.dev.debruyn.ofem</string>
	</array>
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
	<!--
	  Sandbox bypass for the File Provider mount root. The host app's
	  menu bar "Open in Finder" hands an absolute URL under
	  ~/Library/CloudStorage/ to NSWorkspace; without this exception,
	  macOS prompts the user "OneLake does not have permission to open
	  OneLake-<alias>" on every click. Finder itself is not sandboxed and
	  reads the mount fine — this exception only covers the URL hand-off.

	  The path /Library/CloudStorage/ is the parent of every File Provider
	  domain on the machine (iCloud Drive, OneDrive, Dropbox, Google Drive,
	  and our own OneLake-<alias> mounts). home-relative-path exceptions are
	  prefix-based, so it is not possible to scope this to a specific alias
	  because aliases are user-defined at runtime and can be arbitrary strings.
	  NSFileProviderManager.getUserVisibleURL would be the alternative, but
	  it returns a security-scoped URL that must be opened with
	  startAccessingSecurityScopedResource — wiring that through every
	  NSWorkspace.open call site adds significant complexity for no functional
	  benefit. We accept the broad prefix and document it here so future
	  maintainers understand why the narrower path is not feasible.
	-->
	<key>com.apple.security.temporary-exception.files.home-relative-path.read-only</key>
	<array>
		<string>/Library/CloudStorage/</string>
	</array>
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)group.dev.debruyn.ofem</string>
	</array>
</dict>
</plist>
