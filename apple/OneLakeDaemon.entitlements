<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Entitlements for the bundled ofem daemon helper.

  The daemon is sandboxed (com.apple.security.app-sandbox = true) because
  macOS 14.2+ requires a LaunchAgent helper of a sandboxed host app to be
  sandboxed itself. Without this, SMAppService.agent().register() fails with
  "SMAppService target executable must be sandboxed because the app is
  sandboxed".

  All daemon state paths already live inside the App Group container
  (~/Library/Group Containers/<TeamID>.group.dev.debruyn.ofem/) — no path
  migration is needed. The remaining entitlements cover:

    • App Group shared container (config, cache, unix socket).
      app-groups covers this at the kernel level.
    • The unix-domain socket (ofem.sock) it creates in the group container.
      network.server is required for the socket listener; network.client
      for outbound HTTPS to OneLake / Entra.
    • The Keychain: keychain-access-groups lets it share the MSAL token
      cache with the host app. This entitlement requires a paid Developer
      Program team — it is a no-op in unsigned dev builds.

  Note: browser-based auth is handled by delegating to the host app via IPC
  (see the browser-IPC delegation PR) so the daemon itself no longer needs
  to open a browser, which would be blocked in the sandbox anyway.

  The daemon binary must be separately code-signed from the host app with
  THESE entitlements. See docs/packaging-homebrew.md and the Makefile
  apple-build target comments for the release codesign step.
-->
<plist version="1.0">
<dict>
    <!-- Enable App Sandbox. Required by macOS 14.2+ for a LaunchAgent helper
         whose host app is sandboxed (SMAppService validates this). -->
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <!-- App Group shared container (config, cache, socket).
         Team-prefixed so the same identifier works for both Developer
         ID and Mac App Store distribution. -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>$(TeamIdentifierPrefix)group.dev.debruyn.ofem</string>
    </array>
    <!-- Outbound HTTPS to OneLake / Entra ID -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Unix-domain socket listener (IPC) + localhost loopback for browser auth callback -->
    <key>com.apple.security.network.server</key>
    <true/>
    <!-- Shared MSAL Keychain token cache (requires paid Developer Program team) -->
    <key>keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)group.dev.debruyn.ofem</string>
    </array>
</dict>
</plist>
