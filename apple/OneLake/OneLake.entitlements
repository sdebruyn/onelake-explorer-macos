<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.dev.debruyn.ofem</string>
	</array>
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
	<!--
	  Sandbox bypass for the File Provider mount root. The host app's
	  menu bar "Open in Finder" hands an absolute URL under
	  ~/Library/CloudStorage/ to NSWorkspace; without this exception,
	  macOS prompts the user "OneLake does not have permission to open
	  OneLake-<alias>" on every click. Scoped read-only and to the
	  specific subtree so we don't broaden the sandbox beyond what the
	  feature needs. Finder itself is not sandboxed and reads the
	  mount fine — this exception only covers the URL hand-off.
	-->
	<key>com.apple.security.temporary-exception.files.home-relative-path.read-only</key>
	<array>
		<string>/Library/CloudStorage/</string>
	</array>
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)group.dev.debruyn.ofem</string>
	</array>
</dict>
</plist>
